PORT=3108
WECHAT_APPID=change_to_miniprogram_appid
WECHAT_SECRET=change_to_miniprogram_appsecret
OCR_ALLOW_REMOTE_TESSDATA=false
OCR_TESSDATA_DIR=./tessdata
MP_ALLOWED_OPENIDS=openid_1,openid_2
MP_ALLOW_DEV_LOGIN=false
MP_OPEN_LOGIN=false
MP_LOG_DENIED_OPENID=false
MP_USER_ENTITLEMENTS_JSON={}
MP_FREE_RECOMMENDATION_COUNTS=1,3,6
MP_BOOKING_NOTIFY_ENABLED=false
MP_BOOKING_TEMPLATE_ID=
MP_BOOKING_TEMPLATE_FIELDS_JSON={"time1":"dateTime","thing2":"留学咨询预约","thing3":"studentName","thing4":"advisorName","thing5":"note"}
MP_TEACHER_OPENIDS_JSON={"a1":["zhang_teacher_openid"],"a2":["lu_teacher_openid"]}
MP_OWNER_OPENIDS_JSON=["owner_openid"]
MP_ADMIN_OPENIDS_JSON=[]
# 仅存 Render Secret；用于 https://你的后端域名/admin 的电脑后台登录。
MP_ADMIN_WEB_TOKEN=generate_a_different_long_random_secret_in_render_only
MP_DOCUMENT_DOWNLOAD_FREE=true
MP_BOOKING_WEBHOOK_URL=
# 客服消息默认复用预约 Webhook；如需发送到单独的企业群，可另设：
MP_CUSTOMER_MESSAGE_WEBHOOK_URL=
MP_BOOKING_TEACHER_WEBHOOKS_JSON={}
MP_BOOKING_MINIPROGRAM_STATE=trial
MP_BOOKING_SUBSCRIPTION_MODE=one-time
MP_DATA_DIR=./data
MP_MAX_COURSE_VIDEO_BYTES=36700160
MP_MEDIA_SIGNING_SECRET=generate_a_long_random_secret_in_render_only
MP_MEDIA_URL_TTL_SECONDS=3600
# 小程序登录令牌默认有效 30 天，并使用稳定密钥加密；未单独配置时复用 MP_MEDIA_SIGNING_SECRET。
MP_SESSION_SECRET=
MP_SESSION_TTL_SECONDS=2592000
# 通常只配置 MP_DATA_DIR；下面变量仅在确需拆分存储路径时启用。
